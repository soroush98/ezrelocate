# Copy to .env and fill in. .env is gitignored.

# --- Database ---------------------------------------------------------------
DATABASE_URL=postgresql://relocate:relocate@localhost:5432/relocate

# --- Anthropic --------------------------------------------------------------
# Used for: NL query parsing + final recommendation generation.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# --- Voyage AI (embeddings) -------------------------------------------------
# Anthropic recommends Voyage for embeddings (no first-party Anthropic embeddings API).
# Get a key at https://www.voyageai.com/ — free tier covers a portfolio project.
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-3-large

# --- App --------------------------------------------------------------------
APP_ENV=dev
LOG_LEVEL=INFO
