# Copy to .env and fill in. .env is gitignored.

# --- Database ---------------------------------------------------------------
DATABASE_URL=postgresql://relocate:relocate@localhost:5432/relocate

# --- Anthropic --------------------------------------------------------------
# Used for: NL query parsing + final recommendation generation.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# --- Voyage AI (embeddings) -------------------------------------------------
# Anthropic recommends Voyage for embeddings (no first-party Anthropic embeddings API).
# Get a key at https://www.voyageai.com/ — free tier covers a portfolio project.
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-3-large

# --- App --------------------------------------------------------------------
APP_ENV=dev
LOG_LEVEL=INFO

# Public URL of the frontend (used to build Stripe success/cancel redirects).
# Local dev → http://localhost:3000 ; production → https://your-app.vercel.app
PUBLIC_APP_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins for direct browser → backend calls.
# In production the Next.js rewrite proxies server-side, so this rarely matters.
CORS_ORIGINS=http://localhost:3000

# --- Supabase Auth ----------------------------------------------------------
# Project Settings → API → JWT Settings → JWT Secret. The backend verifies
# Supabase-issued JWTs with this secret.
SUPABASE_JWT_SECRET=

# Quotas (defaults shown; override per-environment if needed).
ANON_IP_LIFETIME_LIMIT=5
SUBSCRIBER_DAILY_LIMIT=50

# --- Stripe (test mode) -----------------------------------------------------
# Dashboard → Developers → API keys (use sk_test_... for test mode).
STRIPE_SECRET_KEY=sk_test_...
# Dashboard → Developers → Webhooks → add endpoint → reveal signing secret.
STRIPE_WEBHOOK_SECRET=whsec_...
# Dashboard → Products → create a recurring price, copy its price_... id.
STRIPE_PRICE_ID=price_...

# --- Frontend (Vercel) — set NEXT_PUBLIC_* on the Vercel project, NOT here --
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
